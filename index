<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mingo Mountain Woodworking | Bespoke Custom Cabinetry | Inland Northwest</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #f5f1eb;
      --warm-white: #faf7f2;
      --charcoal: #1e1b17;
      --dark-brown: #12100e;
      --mid-grey: #6a6158;
      --light-grey: #b0a89e;
      --border: #e0d9cf;
      --gold: #a8865a;
      --gold-light: #c9a87a;
      --gold-pale: #e8d5b5;
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'Jost', sans-serif; background: var(--warm-white); color: var(--charcoal); overflow-x: hidden; }

    /* ANNOUNCEMENT */
    .announcement-bar {
      background: var(--charcoal); color: var(--gold-pale);
      text-align: center; padding: 11px 24px;
      font-size: 10.5px; letter-spacing: 0.25em; text-transform: uppercase; font-weight: 300;
    }

    /* HEADER */
    header {
      position: sticky; top: 0; z-index: 200;
      background: rgba(250,247,242,0.97); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border); transition: box-shadow 0.3s;
    }
    header.scrolled { box-shadow: 0 2px 24px rgba(30,27,23,0.08); }

    .header-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 52px; height: 74px; max-width: 1560px; margin: 0 auto;
    }

    .logo {
      font-family: 'Cormorant Garamond', serif; font-size: 15px; font-weight: 400;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--charcoal);
      text-decoration: none; white-space: nowrap; line-height: 1.3;
    }
    .logo-accent {
      display: block; font-size: 9px; letter-spacing: 0.35em; color: var(--gold);
      font-family: 'Jost', sans-serif; font-weight: 300; margin-top: 2px;
    }

    nav { display: flex; gap: 38px; align-items: center; }
    .nav-link {
      font-size: 10.5px; letter-spacing: 0.2em; text-transform: uppercase;
      font-weight: 300; color: var(--charcoal); text-decoration: none;
      position: relative; transition: color 0.3s;
    }
    .nav-link::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 1px; background: var(--gold); transition: width 0.35s ease;
    }
    .nav-link:hover { color: var(--gold); }
    .nav-link:hover::after { width: 100%; }

    .nav-cta {
      font-size: 9.5px; letter-spacing: 0.22em; text-transform: uppercase;
      font-weight: 400; color: var(--warm-white); background: var(--charcoal);
      padding: 11px 26px; text-decoration: none; transition: background 0.3s, color 0.3s; white-space: nowrap;
    }
    .nav-cta:hover { background: var(--gold); color: var(--charcoal); }

    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .hamburger span { display: block; width: 24px; height: 1px; background: var(--charcoal); }

    /* MOBILE NAV */
    .mobile-nav {
      display: none; position: fixed; inset: 0; background: var(--charcoal);
      z-index: 300; flex-direction: column; align-items: center; justify-content: center; gap: 36px;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a {
      font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 300;
      letter-spacing: 0.06em; color: #fff; text-decoration: none; transition: color 0.3s;
    }
    .mobile-nav a:hover { color: var(--gold-light); }
    .mobile-close {
      position: absolute; top: 28px; right: 36px; font-size: 28px; color: rgba(255,255,255,0.6);
      cursor: pointer; background: none; border: none; font-family: 'Jost', sans-serif; transition: color 0.3s;
    }
    .mobile-close:hover { color: var(--gold-light); }

    /* HERO */
    .hero { position: relative; height: 94vh; min-height: 580px; overflow: hidden; display: flex; align-items: flex-end; }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        linear-gradient(160deg, rgba(30,27,23,0.1) 0%, rgba(30,27,23,0.62) 100%),
        url('https://images.squarespace-cdn.com/content/v1/62cde8a17c51f76f100fdf05/1739472004377-60VPJ7BOHXKSAJT7QW5J/18-5308+N+Indian+Bluff+Rd+018.jpg') center/cover no-repeat;
      transform: scale(1.05); animation: heroZoom 14s ease-out forwards;
    }
    @keyframes heroZoom { from { transform: scale(1.05); } to { transform: scale(1.00); } }

    .hero-content {
      position: relative; z-index: 2; padding: 0 80px 90px; max-width: 820px;
      animation: fadeUp 1.2s 0.4s ease both;
    }
    @keyframes fadeUp { from { opacity:0; transform:translateY(32px); } to { opacity:1; transform:translateY(0); } }

    .eyebrow {
      display: flex; align-items: center; gap: 16px;
      font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--gold-pale); font-weight: 300; margin-bottom: 22px;
    }
    .eyebrow::before { content: ''; display: block; width: 44px; height: 1px; background: var(--gold-light); flex-shrink: 0; }

    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(50px, 6.5vw, 96px); font-weight: 300; color: #fff;
      line-height: 1.06; letter-spacing: 0.015em; margin-bottom: 28px;
    }
    .hero h1 em { font-style: italic; color: var(--gold-pale); }

    .hero-desc { font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.78); line-height: 1.9; margin-bottom: 42px; max-width: 500px; }

    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }

    .btn {
      display: inline-block; font-size: 10px; letter-spacing: 0.24em;
      text-transform: uppercase; font-weight: 400; text-decoration: none; padding: 14px 34px; transition: all 0.3s;
    }
    .btn-gold { background: var(--gold); color: #fff; }
    .btn-gold:hover { background: var(--gold-light); color: var(--charcoal); }
    .btn-ghost { border: 1px solid rgba(255,255,255,0.45); color: #fff; }
    .btn-ghost:hover { border-color: var(--gold); background: rgba(168,134,90,0.18); }
    .btn-dark { background: var(--charcoal); color: #fff; }
    .btn-dark:hover { background: var(--gold); }

    /* TRUST BAR */
    .trust-bar { background: var(--charcoal); display: flex; justify-content: center; align-items: center; flex-wrap: wrap; }
    .trust-item {
      display: flex; align-items: center; gap: 14px; padding: 22px 48px;
      color: rgba(255,255,255,0.65); font-size: 10px; letter-spacing: 0.22em;
      text-transform: uppercase; font-weight: 300;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .trust-item:last-child { border-right: none; }
    .trust-icon { color: var(--gold); font-size: 18px; flex-shrink: 0; }

    /* UTILITY */
    .section-wrap { max-width: 1400px; margin: 0 auto; padding: 110px 52px; }

    .tag {
      display: inline-flex; align-items: center; gap: 14px;
      font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--gold); font-weight: 400; margin-bottom: 18px;
    }
    .tag::before { content: ''; display: block; width: 34px; height: 1px; background: var(--gold); }

    h2.display {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 4.2vw, 58px); font-weight: 300;
      line-height: 1.12; letter-spacing: 0.02em; color: var(--charcoal);
    }
    h2.display em { font-style: italic; color: var(--gold); }

    .body-copy { font-size: 14px; font-weight: 300; line-height: 1.95; color: var(--mid-grey); }

    a.arrow-link {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
      font-weight: 400; color: var(--charcoal); text-decoration: none; transition: gap 0.3s, color 0.3s;
    }
    a.arrow-link::after { content: '→'; font-size: 13px; }
    a.arrow-link:hover { color: var(--gold); gap: 16px; }

    /* INTRO SPLIT */
    .intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 100px; align-items: center; }
    .intro-image-wrap { position: relative; height: 620px; }
    .intro-img-main { position: absolute; top: 0; left: 0; width: 78%; height: 88%; object-fit: cover; display: block; }
    .intro-img-accent { position: absolute; bottom: 0; right: 0; width: 52%; height: 50%; object-fit: cover; display: block; border: 10px solid var(--warm-white); }
    .intro-text { padding-right: 20px; }
    .intro-text .body-copy { margin: 28px 0 16px; max-width: 500px; }

    .stat-row { display: flex; gap: 48px; margin-top: 48px; padding-top: 40px; border-top: 1px solid var(--border); }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 52px; font-weight: 300; color: var(--gold); line-height: 1; }
    .stat-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mid-grey); margin-top: 7px; font-weight: 300; }

    /* COLLECTIONS */
    .collections-section { background: var(--cream); }
    .collections-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 56px; gap: 32px; flex-wrap: wrap; }
    .collections-header-text { max-width: 480px; }

    .collections-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; }

    .col-card { position: relative; overflow: hidden; cursor: pointer; background: #c8bfb2; }
    .col-card.tall { grid-row: span 2; }
    .col-card img { width: 100%; height: 100%; object-fit: cover; display: block; min-height: 260px; transition: transform 0.75s cubic-bezier(0.25,0.46,0.45,0.94); }
    .col-card.tall img { min-height: 523px; }
    .col-card:hover img { transform: scale(1.06); }
    .col-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(20,16,14,0.78) 0%, transparent 52%);
      transition: background 0.4s;
    }
    .col-card:hover .col-overlay { background: linear-gradient(to top, rgba(20,16,14,0.88) 0%, rgba(20,16,14,0.2) 58%); }
    .col-info { position: absolute; bottom: 0; left: 0; right: 0; padding: 26px 28px; color: #fff; }
    .col-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 300; letter-spacing: 0.04em; margin-bottom: 5px; }
    .col-card.tall .col-name { font-size: 30px; }
    .col-cta {
      font-size: 9.5px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--gold-pale); font-weight: 300;
      opacity: 0; transform: translateY(8px); transition: opacity 0.35s, transform 0.35s;
      display: flex; align-items: center; gap: 8px;
    }
    .col-cta::after { content: '→'; font-size: 12px; }
    .col-card:hover .col-cta { opacity: 1; transform: translateY(0); }

    /* DARK FEATURE SPLIT */
    .feature-split { display: grid; grid-template-columns: 1fr 1fr; min-height: 700px; }
    .feature-image { position: relative; overflow: hidden; }
    .feature-image img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.9s ease; }
    .feature-image:hover img { transform: scale(1.04); }
    .feature-text { background: var(--charcoal); display: flex; align-items: center; padding: 88px 76px; }
    .feature-text-inner { max-width: 460px; }
    .feature-text .tag { color: var(--gold-light); }
    .feature-text .tag::before { background: var(--gold); }
    .feature-text h2.display { color: #fff; }
    .feature-text .body-copy { color: rgba(255,255,255,0.62); margin: 26px 0 36px; }
    .pull-quote {
      font-family: 'Cormorant Garamond', serif; font-size: 19px; font-style: italic;
      font-weight: 300; color: var(--gold-pale); line-height: 1.7;
      padding-left: 22px; border-left: 2px solid var(--gold); margin: 32px 0;
    }
    .feature-text a.arrow-link { color: var(--gold-pale); }
    .feature-text a.arrow-link:hover { color: var(--gold-light); }

    /* SERVICES */
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 64px; }
    .service-card {
      padding: 48px 40px; background: var(--cream);
      border-top: 2px solid transparent; transition: border-color 0.3s, background 0.3s; cursor: default;
    }
    .service-card:hover { border-color: var(--gold); background: #fff; }
    .service-number { font-family: 'Cormorant Garamond', serif; font-size: 48px; font-weight: 300; color: var(--border); line-height: 1; margin-bottom: 20px; transition: color 0.3s; }
    .service-card:hover .service-number { color: var(--gold-pale); }
    .service-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400; color: var(--charcoal); margin-bottom: 14px; }
    .service-desc { font-size: 13px; font-weight: 300; line-height: 1.85; color: var(--mid-grey); }

    /* FULL BANNER */
    .full-banner { position: relative; height: 560px; overflow: hidden; display: flex; align-items: center; justify-content: center; text-align: center; }
    .full-banner-bg {
      position: absolute; inset: 0;
      background:
        linear-gradient(rgba(20,16,14,0.62), rgba(20,16,14,0.62)),
        url('https://images.squarespace-cdn.com/content/v1/62cde8a17c51f76f100fdf05/1657813648787-VQ2G5BH9AMQGUF7L6L8H/Matthews+Wide+Perspective-1.jpg') center/cover no-repeat;
      transition: transform 0.6s ease;
    }
    .full-banner:hover .full-banner-bg { transform: scale(1.02); }
    .full-banner-content { position: relative; z-index: 2; color: #fff; max-width: 700px; padding: 0 40px; }
    .full-banner-content .tag { justify-content: center; color: var(--gold-pale); }
    .full-banner-content .tag::before { display: none; }
    .banner-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(40px, 5vw, 68px); font-weight: 300; line-height: 1.1; margin: 16px 0 26px; color: #fff; }
    .banner-title em { font-style: italic; color: var(--gold-pale); }
    .banner-sub { font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.72); line-height: 1.85; margin-bottom: 42px; }

    /* PROCESS */
    .process-section { background: var(--cream); }
    .process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; margin-top: 64px; }
    .process-step { padding: 48px 36px; background: #fff; position: relative; overflow: hidden; }
    .process-step::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease;
    }
    .process-step:hover::before { transform: scaleX(1); }
    .step-num { font-family: 'Cormorant Garamond', serif; font-size: 56px; font-weight: 300; color: var(--gold-pale); line-height: 1; margin-bottom: 20px; }
    .step-title { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 400; color: var(--charcoal); margin-bottom: 14px; }
    .step-desc { font-size: 13px; font-weight: 300; line-height: 1.85; color: var(--mid-grey); }

    /* ROOMS */
    .rooms-split { display: grid; grid-template-columns: 1fr 1fr; gap: 3px; }
    .room-card { position: relative; height: 580px; overflow: hidden; cursor: pointer; }
    .room-card img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.8s ease; }
    .room-card:hover img { transform: scale(1.05); }
    .room-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(20,16,14,0.82) 0%, transparent 55%); }
    .room-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 52px; color: #fff; }
    .room-content .tag { color: var(--gold-light); }
    .room-content .tag::before { background: var(--gold-light); }
    .room-title { font-family: 'Cormorant Garamond', serif; font-size: 38px; font-weight: 300; margin: 14px 0 16px; line-height: 1.1; }
    .room-desc { font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.72); line-height: 1.85; margin-bottom: 26px; max-width: 380px; }

    /* TEAM */
    .team-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-top: 64px; }
    .team-image { position: relative; height: 520px; overflow: hidden; }
    .team-image img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
    .team-image-badge { position: absolute; bottom: 32px; right: 32px; background: var(--charcoal); color: #fff; padding: 20px 28px; text-align: center; }
    .badge-num { font-family: 'Cormorant Garamond', serif; font-size: 40px; font-weight: 300; color: var(--gold-light); line-height: 1; }
    .badge-label { font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-top: 6px; }
    .team-text .body-copy { margin: 24px 0 16px; }
    .team-members { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 36px; padding-top: 36px; border-top: 1px solid var(--border); }
    .team-member-name { font-family: 'Cormorant Garamond', serif; font-size: 21px; font-weight: 400; color: var(--charcoal); }
    .team-member-role { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); font-weight: 300; margin-top: 5px; }

    /* NEWSLETTER */
    .newsletter { background: var(--charcoal); text-align: center; padding: 90px 52px; }
    .newsletter .tag { justify-content: center; color: var(--gold-light); }
    .newsletter .tag::before { display: none; }
    .newsletter h2.display { color: #fff; margin: 12px auto 18px; max-width: 540px; }
    .newsletter .body-copy { color: rgba(255,255,255,0.55); margin: 0 auto 40px; max-width: 420px; }
    .nl-form { display: flex; max-width: 460px; margin: 0 auto; }
    .nl-form input {
      flex: 1; padding: 14px 20px; background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.18); border-right: none; color: #fff;
      font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 300; outline: none; transition: border-color 0.3s;
    }
    .nl-form input::placeholder { color: rgba(255,255,255,0.35); }
    .nl-form input:focus { border-color: var(--gold); }
    .nl-form button {
      padding: 14px 28px; background: var(--gold); color: var(--charcoal); border: none;
      font-family: 'Jost', sans-serif; font-size: 9.5px; letter-spacing: 0.22em;
      text-transform: uppercase; font-weight: 400; cursor: pointer; transition: background 0.3s; white-space: nowrap;
    }
    .nl-form button:hover { background: var(--gold-light); }

    /* FOOTER */
    footer { background: var(--dark-brown); padding: 76px 52px 44px; }
    .footer-grid {
      display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 52px;
      max-width: 1400px; margin: 0 auto 64px; padding-bottom: 64px;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 400; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.9); text-decoration: none; display: block; margin-bottom: 20px; }
    .footer-brand-desc { font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.42); line-height: 1.85; max-width: 280px; margin-bottom: 28px; }
    .footer-contact { font-size: 11.5px; font-weight: 300; color: rgba(255,255,255,0.45); line-height: 2.1; }
    .footer-contact a { color: var(--gold); text-decoration: none; }
    .footer-col h4 { font-size: 9.5px; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.85); font-weight: 400; margin-bottom: 22px; }
    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 11px; }
    .footer-col ul a { font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.3s; }
    .footer-col ul a:hover { color: var(--gold); }
    .footer-bottom { max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .footer-bottom p { font-size: 11px; font-weight: 300; color: rgba(255,255,255,0.28); letter-spacing: 0.08em; }
    .footer-legal { display: flex; gap: 28px; }
    .footer-legal a { font-size: 11px; font-weight: 300; color: rgba(255,255,255,0.28); text-decoration: none; letter-spacing: 0.08em; transition: color 0.3s; }
    .footer-legal a:hover { color: var(--gold); }

    /* SCROLL REVEAL */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.75s ease, transform 0.75s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-d1 { transition-delay: 0.1s; }
    .reveal-d2 { transition-delay: 0.22s; }
    .reveal-d3 { transition-delay: 0.34s; }

    /* RESPONSIVE */
    @media (max-width: 1100px) {
      .intro-grid { grid-template-columns: 1fr; gap: 56px; }
      .intro-image-wrap { height: 420px; }
      .feature-split { grid-template-columns: 1fr; }
      .feature-image { height: 440px; }
      .feature-text { padding: 72px 52px; }
      .rooms-split { grid-template-columns: 1fr; }
      .room-card { height: 460px; }
      .team-grid { grid-template-columns: 1fr; gap: 48px; }
      .team-image { height: 380px; }
      .process-steps { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 860px) {
      .header-inner { padding: 0 28px; }
      nav { display: none; }
      .hamburger { display: flex; }
      .hero-content { padding: 0 32px 64px; }
      .section-wrap { padding: 72px 28px; }
      .collections-grid { grid-template-columns: 1fr 1fr; }
      .col-card.tall { grid-row: span 1; }
      .col-card.tall img { min-height: 260px; }
      .services-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .trust-item { padding: 18px 24px; }
    }
    @media (max-width: 560px) {
